# Bu fayldan `.env` nusxa oling va qiymatlarni to'ldiring (`.env` ni git'ga QO'SHMANG).

# ============================================================================
# ASOSIY (majburiy)
# ============================================================================
# Asosiy domen (subdomensiz). Cloudflare tunnel shu domenga ulanadi.
ROOT_DOMAIN=intellectcrm.uz

# FAQAT shu host ilovani (SPA) ochadi.
APP_HOST=app.intellectcrm.uz

# PostgreSQL parol/foydalanuvchi/baza. Parolni kuchli qo'ying. User/DB ixtiyoriy (default: intellectcrm).
POSTGRES_PASSWORD=ChangeMe_Str0ng_Pass
POSTGRES_USER=intellectcrm
POSTGRES_DB=intellectcrm

# Birinchi ishga tushishda (baza bo'sh) yaratiladigan super admin. Birinchi kirgach parolni o'zgartiring.
OWNER_LOGIN=admin
OWNER_PASSWORD=ChangeMe_Owner_Pass1

# JWT imzo kaliti — kamida 32 belgi tasodifiy satr.  Masalan:  openssl rand -base64 48
JWT_KEY=REPLACE_WITH_RANDOM_48_CHARS_MINIMUM_xxxxxxxxxxxxxx

# Cloudflare Tunnel tokeni — Zero Trust → Networks → Tunnels → (tunnel) → token.
TUNNEL_TOKEN=eyJ...your-tunnel-token...

# ============================================================================
# INTEGRATSIYALAR  (.env  ->  CRM sozlamalari)
# ----------------------------------------------------------------------------
# MUHIM: quyidagi integratsiya qiymatlari ENV-WINS — ya'ni .env'da berilgan qiymat har deploy'da
# CRM ichidagi (Sozlamalar) qiymatdan USTUN qo'llanadi. Ya'ni .env'ga yozib `docker compose up -d`
# qilsangiz — UI'da "Saqlash" bosish SHART EMAS, avtomatik aktiv bo'ladi.
# .env'da BO'SH qoldirilgan integratsiya esa odatdagidek UI (Sozlamalar)dan boshqariladi.
# ============================================================================

# ---- Telegram bot (e'lon, ota-ona ro'yxati, yangi lid xabarnomasi, backup yuborish) ----
# Token BotFather'dan. Bo'sh bo'lsa bot ishlamaydi.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_BOT_NAME=
# Markaz kanali (havola yoki @username) — o'quvchi/o'qituvchi ilovasida "kanalga o'tish".
TELEGRAM_CHANNEL=
# Admin chat ID — backup faylini yuborish uchun (masalan 123456789 yoki -100123456789).
TELEGRAM_ADMIN_CHAT_ID=

# ---- Push (Firebase / FCM) ----
# Service account JSON (TO'LIQ, bir qatorda). Bo'sh bo'lsa push yuborilmaydi.
# Maslahat: JSON'ni bir qatorga aylantiring (yangi qatorlarsiz) va bitta qatorda qo'ying.
FCM_SERVICE_ACCOUNT_JSON=

# ---- AI Tahlil (Google Gemini) ----
# API kaliti (aistudio.google.com/app/apikey). Bo'sh bo'lsa AI tahlil ishlamaydi.
GEMINI_API_KEY=
# Model nomi (ixtiyoriy). Default: gemini-3.1-flash-lite
GEMINI_MODEL=gemini-3.1-flash-lite
# Kunlik markaz AI tahlili: yoqilgan (true/false) va soati (0-23, Toshkent, default 8).
AI_ANALYSIS_ENABLED=
AI_ANALYSIS_HOUR=

# ---- SMS (Eskiz.uz) ----
# eskiz.uz kabinet login/parol + tasdiqlangan jo'natuvchi (nikname). Test uchun "4546".
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546

# ---- Speaking (Azure Cognitive Services) ----
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# ---- Turniket / FaceID (o'qituvchilar davomati) ----
# Yoqilgan (true/false), qurilma vendori (hikvision|zkteco), IP/host, port, login/parol.
TURNSTILE_ENABLED=
TURNSTILE_VENDOR=hikvision
TURNSTILE_HOST=
TURNSTILE_PORT=80
TURNSTILE_USERNAME=
TURNSTILE_PASSWORD=

# ---- Call Center (MoiZvonki — bulutli telefoniya, TAVSIYA) ----
# Operator telefoniga MoiZvonki ilovasi o'rnatiladi (SIM bilan) — GSM gateway/Asterisk shart emas.
# DOMAIN — kabinetingiz subdomeni (masalan "intellect" -> intellect.moizvonki.ru).
# USERNAME/API_KEY — kabinet email + Sozlamalar -> Integratsiya bo'limidagi kalit.
# Qo'ng'iroq API_KEY egasining telefonidan chiqadi. Webhook obunasi avtomatik (APP_HOST orqali).
# WEBHOOK_SECRET — ixtiyoriy; bo'sh qoldirilsa API_KEY'dan avtomatik hosil qilinadi.
MOIZVONKI_ENABLED=false
MOIZVONKI_DOMAIN=
MOIZVONKI_USERNAME=
MOIZVONKI_API_KEY=
MOIZVONKI_WEBHOOK_SECRET=

# ---- Call Center (Asterisk + GSM gateway — muqobil) ----
# ASTERISK_HOST — Asterisk serverning CRM yeta oladigan IP'si (bir LAN'da bo'lsa lokal IP,
#   masalan 192.168.1.50; server VPS'da bo'lsa VPN ichki IP — WireGuard/Tailscale.
#   DIQQAT: AMI portini (5038) internetga hech qachon ochmang!).
# USERNAME/PASSWORD — Asterisk manager.conf dagi AMI user (read=call,originate,dialplan
#   write=call,originate; permit=<CRM_IP>).
# OPERATOR_CHANNEL — operator SIP kanali shabloni ({ext} ichki raqam bilan almashadi):
#   PJSIP/{ext} yoki SIP/{ext}. Originate avval operatorni chaqiradi, u ko'targach
#   OUTBOUND_CONTEXT orqali (Exten=raqam) GSM gateway'dan mijozga teradi.
# DEFAULT_OPERATOR_EXT — so'rovda berilmasa ishlatiladigan operator ichki raqami (masalan 101).
# RECORDINGS_PATH — suhbat yozuvlari papkasi KONTEYNER ichidagi yo'l (docker-compose.yml
#   app.volumes'dagi izohga qarang); dialplan MixMonitor faylni ${CRM_CALL_ID}.wav nomlasin.
ASTERISK_ENABLED=false
ASTERISK_HOST=
ASTERISK_PORT=5038
ASTERISK_USERNAME=
ASTERISK_PASSWORD=
ASTERISK_OPERATOR_CHANNEL=PJSIP/{ext}
ASTERISK_OUTBOUND_CONTEXT=from-internal
ASTERISK_DEFAULT_OPERATOR_EXT=
ASTERISK_CALLER_ID=
ASTERISK_RECORDINGS_PATH=

# ---- Kamera (videokuzatuv) ----
CAMERA_ENABLED=

# ---- Avtomatik to'lov eslatmasi (qarzdorlarga Telegram+push) ----
PAYMENT_REMINDERS_ENABLED=

# ---- Telegram backup (kunlik .sql.gz/JSON) ----
# Yoqilgan (true/false) + vaqti. Toshkent = UTC+5. App-side backup soat:daqiqani Toshkent vaqtida o'qiydi.
BACKUP_TELEGRAM_ENABLED=
BACKUP_HOUR=21
BACKUP_MINUTE=00
