# Bu fayldan `.env` nusxa oling va qiymatlarni to'ldiring (`.env` ni git'ga QO'SHMANG).

# Sizning asosiy domeningiz (subdomensiz). Maktablar shuning subdomeni bo'ladi.
ROOT_DOMAIN=maktab.uz

# SQL Server 'sa' paroli — kuchli bo'lsin (kamida 8 belgi, katta/kichik harf + raqam + belgi).
SA_PASSWORD=ChangeMe_Str0ng!Pass

# JWT imzo kaliti — kamida 32 belgi tasodifiy satr. Masalan:
#   openssl rand -base64 48
JWT_KEY=REPLACE_WITH_RANDOM_48_CHARS_MINIMUM_xxxxxxxxxxxxxx

# Cloudflare Tunnel tokeni — Zero Trust → Networks → Tunnels → (tunnel) → token.
TUNNEL_TOKEN=eyJ...your-tunnel-token...
