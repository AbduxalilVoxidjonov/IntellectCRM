# Bu fayldan `.env` nusxa oling va qiymatlarni to'ldiring (`.env` ni git'ga QO'SHMANG).

# Asosiy domen (subdomensiz). Cloudflare tunnel shu domenga ulanadi.
ROOT_DOMAIN=intellectcrm.uz

# FAQAT shu host ilovani (SPA) ochadi; qolgan hostlar landing sahifani ko'radi.
APP_HOST=app.intellectcrm.uz

# PostgreSQL parol/foydalanuvchi/baza. Parolni kuchli qo'ying. User/DB ixtiyoriy (default: intellectcrm).
POSTGRES_PASSWORD=ChangeMe_Str0ng_Pass
POSTGRES_USER=intellectcrm
POSTGRES_DB=intellectcrm

# Birinchi ishga tushishda (baza bo'sh) yaratiladigan super admin. Parolni kuchli qo'ying va birinchi kirgach o'zgartiring.
OWNER_LOGIN=admin
OWNER_PASSWORD=ChangeMe_Owner_Pass1

# JWT imzo kaliti — kamia 32 belgi tasodifiy satr. Masalan:
#   openssl rand -base64 48
JWT_KEY=REPLACE_WITH_RANDOM_48_CHARS_MINIMUM_xxxxxxxxxxxxxx

# AI Tahlil (Google Gemini) modeli. Kalit CRM ichidan (Sozlamalar → AI Tahlil) kiritiladi,
# bu yerda faqat model nomi. Default: gemini-3.1-flash-lite
GEMINI_MODEL=gemini-3.1-flash-lite

# Cloudflare Tunnel tokeni — Zero Trust → Networks → Tunnels → (tunnel) → token.
TUNNEL_TOKEN=eyJ...your-tunnel-token...

# ============================================================================
# BACKUP TELEGRAM (ixtiyoriy) — kunlik .sql.gz backup'ni Telegram'ga yuborish
# ============================================================================
# Telegram Bot API tokeni (BotFather'dan). Bo'sh bo'lsa: backup Telegram'ga yuborilmaydi.
TELEGRAM_BOT_TOKEN=

# Admin chat ID raqami (administrator/privat chat @/group ID). Bo'sh bo'lsa: backup Telegram'ga yuborilmaydi.
# Masalan: 123456789 yoki -100123456789 (privat kanal uchun)
TELEGRAM_ADMIN_CHAT_ID=

# Backup vaqti (UTC) — ZAXIRA qiymat. ASOSIYsi ilovadan: Sozlamalar -> Telegram bot -> Backup
# (soat:daqiqa, chat ID, yoqilgan/o'chiq, bot token DB'da saqlanadi va backup shu yerdan o'qiydi).
# Bu env faqat DB bo'sh bo'lganda ishlatiladi. Toshkent = UTC+5 (02:00 Toshkent -> HOUR=21).
BACKUP_HOUR=21
BACKUP_MINUTE=00

