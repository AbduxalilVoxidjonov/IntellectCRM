# Backend API manzili.
# Integratsiyalangan rejimda nisbiy "/api" ishlatiladi — Vite proxy uni
# ASP.NET backendiga (SchoolLms.Server) yo'naltiradi (vite.config.ts).
VITE_API_BASE_URL=/api

# Mock rejim: backend API tayyor bo'lganda "false" qiling.
# Backend (SchoolLms.Server) tayyor — real API ishlatilmoqda.
VITE_USE_MOCK=false
